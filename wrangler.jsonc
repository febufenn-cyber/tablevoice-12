{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tablevoice",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-12",
  "minify": true,
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": ["/v1/*", "/health"]
  },
  "vars": {
    "DEV_AUTH_BYPASS": "false"
  }
}
